#include <stdio.h>
#include <stdlib.h>

int p, r;
int avail[10], max[10][10], alloc[10][10], need[10][10];
int safeSeq[10];

void get() {
    int i, j;

    printf("\nENTER THE NUMBER OF PROCESSES: ");
    scanf("%d", &p);

    printf("ENTER THE NUMBER OF RESOURCE TYPES: ");
    scanf("%d", &r);

    printf("\nENTER AVAILABLE RESOURCES:\n");
    for (j = 0; j < r; j++) {
        printf("Resource %d: ", j + 1);
        scanf("%d", &avail[j]);
    }

    printf("\nENTER MAXIMUM RESOURCES REQUIRED:\n");
    for (i = 0; i < p; i++) {
        printf("Process %d:\n", i + 1);
        for (j = 0; j < r; j++) {
            printf("Resource %d: ", j + 1);
            scanf("%d", &max[i][j]);
        }
    }

    printf("\nENTER ALLOCATED RESOURCES:\n");
    for (i = 0; i < p; i++) {
        printf("Process %d:\n", i + 1);
        for (j = 0; j < r; j++) {
            printf("Resource %d: ", j + 1);
            scanf("%d", &alloc[i][j]);
        }
    }
}

void calculateNeed() {
    int i, j;
    for (i = 0; i < p; i++)
        for (j = 0; j < r; j++)
            need[i][j] = max[i][j] - alloc[i][j];
}

void bankersAlgorithm() {
    int finish[10] = {0};
    int work[10];
    int i, j, count = 0;

    for (i = 0; i < r; i++)
        work[i] = avail[i];

    while (count < p) {
        int found = 0;

        for (i = 0; i < p; i++) {
            if (!finish[i]) {
                int possible = 1;

                for (j = 0; j < r; j++) {
                    if (need[i][j] > work[j]) {
                        possible = 0;
                        break;
                    }
                }

                if (possible) {
                    for (j = 0; j < r; j++)
                        work[j] += alloc[i][j];

                    safeSeq[count++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }

        if (!found) {
            printf("\nSystem is NOT in safe state (Deadlock possible).\n");
            return;
        }
    }

    printf("\nSystem is in SAFE state.\nSafe Sequence: ");
    for (i = 0; i < p; i++)
        printf("P%d ", safeSeq[i]);
    printf("\n");
}

int main() {
    get();
    calculateNeed();
    bankersAlgorithm();
    return 0;
}
